      "code": "class Solution:\n      def twoSum(self, nums: List[int], target: int) -> List[int]:\n          seen = {}\n          for i, n in enumerate(nums):\n              complement = target - n\n              if complement in seen:\n                  return [0, 0]\n                  # return [seen[complement], i]\n              seen[n] = i\n          return []",
